# Server Configuration
MCP_HOST=127.0.0.1
MCP_PORT=9898
CORS_ORIGINS=*

# Authentication Mode
# none  -> local development / quick trial (default, binds to localhost)
# token -> simple static bearer token for personal or intranet deployments
# jwt   -> production mode using FastMCP JWTVerifier + OIDC/JWKS
STOCK_MCP_AUTH_MODE=none

# Static Bearer Token (required only when STOCK_MCP_AUTH_MODE=token)
STOCK_MCP_STATIC_BEARER_TOKEN=

# FastMCP JWT Authentication (required only when STOCK_MCP_AUTH_MODE=jwt)
FASTMCP_SERVER_AUTH=fastmcp.server.auth.providers.jwt.JWTVerifier
FASTMCP_SERVER_AUTH_JWT_JWKS_URI=
FASTMCP_SERVER_AUTH_JWT_ISSUER=
FASTMCP_SERVER_AUTH_JWT_AUDIENCE=stock-mcp
FASTMCP_SERVER_AUTH_JWT_REQUIRED_SCOPES=mcp.read

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# PostgreSQL
# Local bare-metal runs can point to an existing database.
# Docker Compose starts its own Postgres and maps it to DOCKER_POSTGRES_PORT on the host.
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=valuecell
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=10
DOCKER_POSTGRES_PORT=15432
DOCKER_POSTGRES_USER=postgres
DOCKER_POSTGRES_PASSWORD=postgres
DOCKER_POSTGRES_DB=valuecell

# Security Master backend (auto|postgres|sqlite)
SECURITY_MASTER_BACKEND=postgres
SECURITY_MASTER_SQLITE_PATH=data/security_master.sqlite

# Data Source: Tushare (Optional, for A-Shares with higher priority)
# Register at https://tushare.pro/
# Set TUSHARE_ENABLED=True and provide token to enable
# If disabled, Akshare and Baostock will be used as fallback
TUSHARE_ENABLED=False
TUSHARE_TOKEN=
# Optional custom tushare endpoint (for private deployment / mirror)
TUSHARE_HTTP_URL=http://lianghua.nanyangqiankun.top

# Data Source: Finnhub (Optional, for US Stocks)
# Register at https://finnhub.io/
# Set FINNHUB_ENABLED=True and provide API key to enable
FINNHUB_ENABLED=False
FINNHUB_API_KEY=

# Data Source: Baostock (Free, no key needed)
BAOSTOCK_ENABLED=True

# Proxy Configuration (Optional, for foreign providers only)
# Foreign providers such as Yahoo, Finnhub, Futures, Alpha Vantage, Twelve Data,
# FRED, CCXT, Crypto, and EDGAR use explicit adapter-level proxy settings.
# Domestic providers such as Tushare, Akshare, and Baostock stay direct.
# In Docker Compose, PROXY_HOST is overridden to host.docker.internal by default.
# Override that behavior with DOCKER_PROXY_HOST if your host proxy is elsewhere.
PROXY_ENABLED=False
PROXY_HOST=127.0.0.1
PROXY_PORT=7890
DOCKER_PROXY_HOST=host.docker.internal

# Timeout Configuration
# Hard timeout for each MCP tool call (seconds)
MCP_TOOL_TIMEOUT_SECONDS=35
# Per-provider timeout for adapter routing/failover (seconds)
PROVIDER_CALL_TIMEOUT_SECONDS=12
# Default HTTP request timeout for internal clients (seconds)
HTTP_REQUEST_TIMEOUT_SECONDS=20

# API Keys for News & Search (Optional)
# News search currently uses Tavily as the unified backend.
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
NEWS_API_KEY=
TAVILY_API_KEY=
FRED_API_KEY=
OPENROUTER_API_KEY=

# Logging
LOG_FILE=logs/stock-mcp.log

# Third-party Model Configuration (Optional)
# Use a custom model provider instead of default OpenAI
THIRD_PARTY_MODEL_API_KEY=
THIRD_PARTY_MODEL_BASE_URL=
THIRD_PARTY_MODEL_NAME=
